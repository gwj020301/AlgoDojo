# Runtime environment: dev | prod | test
ENV=dev
DEBUG=true

# PostgreSQL (SQLAlchemy async URL, asyncpg driver)
DATABASE_URL=postgresql+asyncpg://algodojo:algodojo@localhost:5432/algodojo

# Redis (judge task queue + result cache)
REDIS_URL=redis://localhost:6379/0

# Frontend base URL (OAuth redirects target this)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# GitHub OAuth — create an app at https://github.com/settings/developers
# Authorization callback URL must be {BACKEND_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_SCOPE=read:user

# JWT — CHANGE jwt_secret in production
JWT_SECRET=dev-insecure-secret-change-me-in-production-0123456789
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
