# Copy to deploy/.env and fill in. Used by the api/worker/init compose services.

# GitHub OAuth (https://github.com/settings/developers)
# Authorization callback URL: {BACKEND_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_SCOPE=read:user

# JWT — MUST change in production (>= 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-string-please

# Public URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Judge tuning (optional)
JUDGE_CONCURRENCY=2
JUDGE_TIME_LIMIT_S=2.0
JUDGE_MEMORY_LIMIT_MB=256
